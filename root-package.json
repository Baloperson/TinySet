{
  "name": "quop",
  "version": "3.6.5",
  "description": "High-performance in-memory entity store with spatial indexing, cached queries, live views, and transactions. ~8kB, zero dependencies.",
  "keywords": [
    "entity-store",
    "in-memory-database",
    "spatial-index",
    "ecs",
    "entity-component-system",
    "game-dev",
    "query-engine",
    "reactive",
    "state-management",
    "live-views"
  ],
  "type": "module",
  "main": "./QuOp.js",
  "types": "./QuOp.d.ts",
  "exports": {
    ".": {
      "types": "./QuOp.d.ts",
      "import": "./QuOp.js",
      "default": "./QuOp.js"
    },
    "./plus": {
      "types": "./QuOp.d.ts",
      "import": "./QuOp.plus.js",
      "default": "./QuOp.plus.js"
    }
  },
  "files": [
    "QuOp.js",
    "QuOp.plus.js",
    "QuOp.d.ts",
    "README.md",
    "LICENSE"
  ],
  "author": "R Balog <baloperson>",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Baloperson/QuOp.git"
  },
  "homepage": "https://github.com/Baloperson/QuOp#readme",
  "bugs": {
    "url": "https://github.com/Baloperson/QuOp/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "test": "node --test test.js",
    "bench": "node benchmarks/index.js"
  }
}

{
  "name": "tinyop",
  "version": "1.0.0",
  "description": "Typed entity store with spatial indexing, compound queries, and reactive events. 8kB, zero dependencies.",
  "type": "module",
  "main": "./tinyop.js",
  "exports": {
    ".": {
      "import": "./tinyop.js",
      "default": "./tinyop.js"
    },
    "./plus": {
      "import": "./tinyop.plus.js",
      "default": "./tinyop.plus.js"
    }
  },
  "files": [
    "tinyop.js",
    "tinyop.plus.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "entity-component-system",
    "spatial-index",
    "state-management",
    "in-memory",
    "query",
    "game-dev",
    "ecs",
    "reactive"
  ],
  "author": "Baloperson",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Baloperson/TinyOp.git"
  },
  "homepage": "https://github.com/Baloperson/TinyOp#readme",
  "bugs": {
    "url": "https://github.com/Baloperson/TinyOp/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
